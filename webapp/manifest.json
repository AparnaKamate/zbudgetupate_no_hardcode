{
	"_version": "1.7.0",
	"sap.app": {
		"id": "zsapzbudgetupdate",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"tags": {
			"keywords": []
		},
		"dataSources": {
			"mainService": {
				"uri": "/sap/opu/odata/sap/ZSB_BUDGET_DATA1/",
				"type": "OData",
				"settings": {
					"annotations": [
						"ZSB_BUDGET_DATA1_VAN"
					],
					"localUri": "localService/metadata.xml"
				}
			},
			"ZSB_BUDGET_DATA1_VAN": {
				"uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='ZSB_BUDGET_DATA1_VAN',Version='0001')/$value/",
				"type": "ODataAnnotation",
				"settings": {
					"localUri": "localService/ZSB_BUDGET_DATA1_VAN.xml"
				}
			}
		},
		"offline": false,
		"sourceTemplate": {
			"id": "ui5template.smartTemplate",
			"version": "1.40.12"
		}
	},
	"zsapzbudgetupdate.uploadConfig": {
		"_comment": "Config for ListReportExt.controller.js file-upload feature. Change values here — controller reads them, no hardcoding in JS.",
		"service": {
			"url": "/sap/opu/odata/sap/ZEXCEL_BUDGET_SRV/",
			"entitySet": "EXCEL_DATASet"
		},
		"upload": {
			"maxFileSizeMB": 15,
			"allowedExtensions": ["xlsx", "xls", "csv"],
			"blankPlaceholder": "-"
		},
		"contentTypeMap": {
			"xlsx": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
			"xls": "application/vnd.ms-excel",
			"csv": "text/csv"
		},
		"columnMap": {
			"budget request type": "RequestType",
			"monitoring head code (source)": "MoniFrom",
			"monitoring head code (receiving)": "MoniTo",
			"monitoring head desc.(source)": "MoniFromDesc",
			"monitoring head desc.(receiving)": "MoniToDesc",
			"wbs id (source)": "FromWbs",
			"wbs id (receiving)": "ToWbs",
			"requested amount": "RequestedAmt",
			"year(source)": "FromYear",
			"year (receiving)": "ToYear",
			"justifictaion": "Justification",
			"justification": "Justification"
		},
		"fieldLabel": {
			"RequestType": "Budget Request Type",
			"MoniFrom": "Monitoring Head code (Source)",
			"MoniTo": "Monitoring Head code (Receiving)",
			"MoniFromDesc": "Monitoring Head Desc.(Source)",
			"MoniToDesc": "Monitoring Head Desc.(Receiving)",
			"FromWbs": "WBS ID (Source)",
			"ToWbs": "WBS ID (Receiving)",
			"RequestedAmt": "Requested Amount",
			"FromYear": "Year(Source)",
			"ToYear": "Year (Receiving)",
			"Justification": "Justification"
		},
		"requiredHeaderColumns": ["RequestType", "FromWbs", "ToWbs", "RequestedAmt", "FromYear", "Justification"]
	},
	"zsapzbudgetupdate.toWbsVisibilityConfig": {
		"_comment": "Config for ObjectPageExt.controller.js — To-WBS section show/hide and read-only fields. Change values here — controller reads them, no hardcoding in JS.",
		"toWbsSectionTitle": "Receiving WBS",
		"requestTypeTextProperty": "RequestType",
		"transferValue": "T",
		"readOnlyFields": ["VernrFrom"]
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		},
		"supportedThemes": [
			"sap_hcb",
			"sap_belize"
		]
	},
	"sap.ui5": {
		"resources": {
			"js": [
				{
					"uri": "thirdparty/xlsx/xlsx.full.min.js"
				}
			],
			"css": []
		},
		"dependencies": {
			"minUI5Version": "1.32.1",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
				"sap.ui.comp": {},
				"sap.uxap": {},
				"sap.suite.ui.generic.template": {},
				"sap.ui.layout": {},
				"sap.ui.unified": {},
				"sap.ushell": {},
				"sap.collaboration": {}
			},
			"components": {}
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties"
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties"
			},
			"i18n|sap.suite.ui.generic.template.ListReport|ZC_BUDGET_DATA": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/ListReport/ZC_BUDGET_DATA/i18n.properties"
			},
			"i18n|sap.suite.ui.generic.template.ObjectPage|ZC_BUDGET_DATA": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/ObjectPage/ZC_BUDGET_DATA/i18n.properties"
			},
			"": {
				"dataSource": "mainService",
				"settings": {
					"defaultBindingMode": "TwoWay",
					"defaultCountMode": "Inline",
					"refreshAfterChange": false
				}
			}
		},
		"extends": {
			"extensions": {
				"sap.ui.controllerExtensions": {
					"sap.suite.ui.generic.template.ListReport.view.ListReport": {
						"controllerName": "zsapzbudgetupdate.ext.controller.ListReportExt",
						"sap.ui.generic.app": {
							"ZC_BUDGET_DATA": {
								"EntitySet": "ZC_BUDGET_DATA",
								"Actions": {
									"UploadBudgetFile": {
										"id": "UploadBudgetFileBtn",
										"text": "Upload File",
										"press": "onUploadBudgetFile",
										"requiresSelection": false
									}
								}
							}
						}
					},
					"sap.suite.ui.generic.template.ObjectPage.view.Details": {
						"controllerName": "zsapzbudgetupdate.ext.controller.ObjectPageExt"
					}
				}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		}
	},
	"sap.ui.generic.app": {
		"_version": "1.3.0",
		"pages": {
			"ListReport|ZC_BUDGET_DATA": {
				"entitySet": "ZC_BUDGET_DATA",
				"component": {
					"name": "sap.suite.ui.generic.template.ListReport",
					"list": true
				},
				"pages": {
					"ObjectPage|ZC_BUDGET_DATA": {
						"entitySet": "ZC_BUDGET_DATA",
						"component": {
							"name": "sap.suite.ui.generic.template.ObjectPage"
						}
					}
				}
			}
		}
	},
	"sap.platform.hcp": {
		"uri": ""
	}
}